# ProfeTEC.IA — Frontend env
# Copiar a .env.local y rellenar con los valores de tu proyecto Firebase.
# Obtener en: Firebase Console → Configuración del proyecto → Tus apps → Web

VITE_API_URL=http://localhost:8080

# Firebase Web Config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
