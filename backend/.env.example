# ProfeTEC.IA — Backend env
# Copiar a .env y rellenar. NUNCA commitear .env.

APP_NAME=ProfeTEC.IA
APP_ENV=development
APP_VERSION=0.1.0

# Puerto (Cloud Run inyecta PORT automáticamente en produccion)
PORT=8080

# Orígenes permitidos para CORS (separados por coma)
# Puerto del frontend en desarrollo (Vite usa 5173 o 5174 si 5173 está ocupado)
CORS_ORIGINS=http://localhost:5174
ALLOWED_EMAIL_DOMAINS=tecsup.edu.pe
# Para demos locales con cualquier cuenta:
# ALLOWED_EMAIL_DOMAINS=*

# --- Sprint 1: Firebase ---
# FIREBASE_PROJECT_ID=profetec-ia
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json   ← path a la service account key
#   Obtener en: Firebase Console → Configuración → Cuentas de servicio → Generar clave privada

# --- Sprint 2+: Vertex AI ---
# GCP_PROJECT_ID=profetec-ia
# GCP_REGION=us-central1
# VERTEX_AI_MODEL=gemini-2.5-flash
# GCS_BUCKET_NAME=profetec-materiales

# --- RAG ---
RAG_TOP_K=3
RAG_SCORE_MINIMO=0.3
RAG_MAX_CHUNKS_SCAN=500
RAG_BACKEND=firestore_scan

# --- BigQuery Vector Search (opcional) ---
# Usar RAG_BACKEND=bigquery_vector para recuperar chunks con VECTOR_SEARCH.
BIGQUERY_DATASET=profetec_rag
BIGQUERY_CHUNKS_TABLE=chunks
BIGQUERY_LOCATION=US
